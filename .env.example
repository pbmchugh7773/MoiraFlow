# ---- Database ----
POSTGRES_USER=moiraflow
POSTGRES_PASSWORD=moiraflow
POSTGRES_DB=moiraflow
DATABASE_URL=postgresql+psycopg://moiraflow:moiraflow@postgres:5432/moiraflow

# ---- Temporal ----
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
MOIRAFLOW_TASK_QUEUE=moiraflow-server

# ---- Redis (UI pub/sub) ----
REDIS_URL=redis://redis:6379/0

# ---- MinIO (artifacts) ----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=moiraflow-artifacts
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ---- Auth ----
JWT_SECRET=dev-insecure-secret-change-me-please-32bytes
JWT_EXPIRES_SECONDS=3600
SECRETS_MASTER_KEY=dev-insecure-master-key-change-me
ADMIN_EMAIL=admin@moiraflow.local
ADMIN_PASSWORD=admin

# ---- Host ports (left of the colon in compose) ----
API_PORT=8001
POSTGRES_PORT=5433
REDIS_PORT=6380
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
